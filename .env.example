# Deployment profile. Non-secret.
# Allowed: local, public-cloud, institution, closed
DEPLOYMENT_PROFILE=local

# Ollama server-side inference settings. Never expose these with NEXT_PUBLIC_.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT_MS=30000
OLLAMA_ENABLED=true
OLLAMA_NO_CLOUD=false
OLLAMA_SYNTHESIS_ENABLED=false

# Law.go.kr Open API OC key. Secret. Server-side only.
LAW_OPEN_API_OC=

# Public data portal service key. Secret. Server-side only.
PUBLIC_DATA_API_KEY=

# Playwright local verification target. Non-secret.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
